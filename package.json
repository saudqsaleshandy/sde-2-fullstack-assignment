{
  "name": "sequencer-takehome",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "worker": "npm --workspace backend run worker",
    "setup:db": "npm --workspace backend run setup:db",
    "build": "npm --workspace backend run build && npm --workspace frontend run build",
    "typecheck": "npm --workspace backend run typecheck && npm --workspace frontend run typecheck"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
